ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_strong
SESSION_SECRET=change_me_to_a_long_random_string
DB_PATH=/data/canaan_scanner.sqlite

MINER_PORT=4028
SCAN_CONCURRENCY=20
CONNECT_TIMEOUT_S=2.0
READ_TIMEOUT_S=5.0
MAX_IPS_PER_SCAN=5000

# Admin debug ZIP export max size (bytes)
DEBUG_EXPORT_MAX_BYTES=52428800

# Docker Compose: set GIT_SHA before `docker compose build` so the image records this commit
# (also written to app/.deploy_sha inside the image when not "unknown")
# GIT_SHA=

# Optional runtime override of deploy identity (highest priority; no rebuild)
# DEPLOY_SHA=

# Optional: GitHub update checks (Settings / banner)
# GITHUB_TOKEN=
# GITHUB_REPO=Erik-Soluna/canaan-local-scanner
# GITHUB_UPDATE_CACHE_TTL_S=600

# Optional: Settings "Trigger deploy" — POST JSON to this URL (admin only; when main is ahead)
# DEPLOY_WEBHOOK_URL=https://example.com/your-ci-or-host-hook
# DEPLOY_WEBHOOK_SECRET=
